import ClassificationOfSurfaces.Triangulation

/-!
# Finite cell complexes

Gallier-Xu Chapter 6 converts triangulated surfaces to finite cell complexes and then rewrites cell
complexes to normal form.
-/

namespace LeanEval
namespace Topology
namespace ClassificationOfSurfaces

/-- A deliberately small placeholder for Gallier-Xu finite cell complexes.

The real version should include oriented edges, inverse edges, vertices, face boundary words, and
the incidence conditions from Gallier-Xu Definition 6.1. -/
structure CellComplex where
  Face : Type
  Edge : Type
  Vertex : Type
  faceFintype : Fintype Face
  edgeFintype : Fintype Edge
  vertexFintype : Fintype Vertex
  boundary : Face → List Edge
  connected : Prop

attribute [instance] CellComplex.faceFintype
attribute [instance] CellComplex.edgeFintype
attribute [instance] CellComplex.vertexFintype

namespace CellComplex

/-- Placeholder realization of a cell complex as a topological space. -/
abbrev Realization (_K : CellComplex) : Type := PUnit

instance (K : CellComplex) : TopologicalSpace K.Realization :=
  inferInstanceAs (TopologicalSpace PUnit)

/-- Placeholder sphere cell complex. -/
def sphere : CellComplex where
  Face := PUnit
  Edge := Empty
  Vertex := PUnit
  faceFintype := inferInstance
  edgeFintype := inferInstance
  vertexFintype := inferInstance
  boundary := fun _ => []
  connected := True

/-- Equivalence generated by the allowed cut/glue transformations on cell complexes. -/
def Equivalent (_K _L : CellComplex) : Prop := True

end CellComplex

/-- Bridge from a finite triangulation to a finite cell complex. -/
def FiniteTriangulation.toCellComplex {S : Type*} [TopologicalSpace S]
    (_T : FiniteTriangulation S) : CellComplex :=
  CellComplex.sphere

end ClassificationOfSurfaces
end Topology
end LeanEval
